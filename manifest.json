{
  "manifest_version": 3,
  "name": "Tel to WhatsApp",
  "version": "1.0.0",
  "description": "Adds a right-click option to open phone numbers in WhatsApp.",
  "icons": {
    "16": "icons/whatsapp-16.png",
    "32": "icons/whatsapp-32.png",
    "48": "icons/whatsapp-48.png",
    "128": "icons/whatsapp-128.png"
  },
  "permissions": [
    "contextMenus"
  ],
  "background": {
    "service_worker": "background.js"
  }
}
