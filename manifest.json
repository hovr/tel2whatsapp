{
  "manifest_version": 3,
  "name": "Tel2WhatsApp",
  "version": "1.0.14",
  "description": "Adds a right-click option to open phone numbers in WhatsApp.",
  "icons": {
    "16": "icons/whatsapp-16.png",
    "32": "icons/whatsapp-32.png",
    "48": "icons/whatsapp-48.png",
    "128": "icons/whatsapp-128.png"
  },
  "permissions": [
    "contextMenus",
    "storage",
    "scripting",
    "activeTab"
  ],
  "host_permissions": [
    "https://raw.githubusercontent.com/*",
    "https://api.country.is/*",
    "https://ipapi.co/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/whatsapp-16.png",
      "32": "icons/whatsapp-32.png",
      "48": "icons/whatsapp-48.png",
      "128": "icons/whatsapp-128.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  }
}
